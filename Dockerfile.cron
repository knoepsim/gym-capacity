# Leichtgewichtiger Cron-Container der nur die API aufruft
FROM alpine:latest

RUN apk add --no-cache curl

# Starte einen einfachen Loop der die API alle 5 Minuten aufruft
CMD ["sh", "-c", "while true; do echo \"[$(date)] Calling fetch API...\"; if [ -n \"$FETCH_API_KEY\" ]; then curl -X POST http://web:3000/api/fetch -H 'Content-Type: application/json' -H \"x-api-key: $FETCH_API_KEY\" || echo 'Fetch fehlgeschlagen'; else curl -X POST http://web:3000/api/fetch -H 'Content-Type: application/json' || echo 'Fetch fehlgeschlagen'; fi; sleep 300; done"]
